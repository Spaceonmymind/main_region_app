# Токен из MAX для партнёров:
# Чат-боты → Перейти → Расширенные настройки → Настроить
BOT_TOKEN=

# HTTP-порт health-check и webhook.
PORT=3001

# Необязательно для проверки приветственных сообщений.
# Диплинк мини-приложения после привязки к боту в MAX.
# Формат: https://max.ru/<имя_бота>?startapp
MINI_APP_URL=
