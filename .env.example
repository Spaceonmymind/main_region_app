# Токен из MAX для партнёров:
# Чат-боты → Перейти → Расширенные настройки → Настроить
BOT_TOKEN=

# HTTP-порт health-check и webhook.
PORT=3001

# Публичный HTTPS-адрес, который нужно указать в MAX для партнёров:
# Чат-боты → Перейти → Расширенные настройки → Настроить → URL мини-приложения.
PUBLIC_MINI_APP_URL=https://service-bot.vi.gov45.ru

# Диплинк, который бот ставит в кнопку «Открыть сервисы».
# Именно он открывает привязанное мини-приложение внутри MAX.
# Замените <botName> на имя вашего бота в MAX.
MINI_APP_DEEPLINK=https://max.ru/<botName>?startapp
